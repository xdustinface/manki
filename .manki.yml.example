# Manki configuration
# Place this file as .manki.yml in your repository root

# Claude model for reviews (default: claude-opus-4-6)
# model: claude-opus-4-6

# Automatically review PRs on open/update (default: true)
# When false, reviews only run via @manki review
# auto_review: true

# Auto-approve when all blocking findings are resolved (default: true)
# Triggers on thread resolution and via @manki check
# auto_approve: true

# Review language (default: en)
# review_language: en

# File filtering
# include_paths:
#   - "**/*"
# exclude_paths:
#   - "*.lock"
#   - "dist/**"
#   - "*.generated.*"

# Maximum diff lines before skipping review (default: 10000)
# max_diff_lines: 10000

# Team sizing: auto (default), small (3 agents), medium (5), large (7)
# review_level: auto
# review_thresholds:
#   small: 100   # diffs under this many lines get a small team
#   medium: 500  # diffs under this many lines get a medium team

# Custom reviewer agents (added to the built-in 7-agent pool)
# The built-in pool covers: Security, Architecture, Correctness, Testing,
# Performance, Maintainability, Dependencies. Custom reviewers get a scoring
# boost during team selection.
# reviewers:
#   - name: "Protocol Compliance"
#     focus: "DIP compliance, consensus rules, protocol-specific invariants"

# Additional instructions injected into all reviewer prompts
# instructions: |
#   This is a Rust project. Focus on ownership and error handling.

# Review memory (requires memory_repo_token)
# Stores learnings, suppressions, and patterns to improve reviews over time
# memory:
#   enabled: false
#   repo: ""  # defaults to {owner}/review-memory
